{
  "name": "erp-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ERP — admin API (Express + Prisma + MySQL)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "bash scripts/db-push-safe.sh",
    "db:reset": "DB_RESET=1 bash scripts/db-push-safe.sh",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "node ./node_modules/prisma/build/index.js studio --schema prisma/schema.prisma",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
