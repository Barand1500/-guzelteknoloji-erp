# CloudPanel → Site → erp.guzelteknoloji.com → Vhost / Nginx Directives
# server { ... } blogunun ICINE ekleyin (frontend location'dan once veya sonra).
#
# Document root: ~/htdocs/erp.guzelteknoloji.com/frontend
# PM2 API:       erp-api @ 127.0.0.1:3006

location /api {
    proxy_pass http://127.0.0.1:3006;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# Trailing slash KULLANMAYIN: proxy_pass http://127.0.0.1:3006/;  (yanlis)
# Dogru: proxy_pass http://127.0.0.1:3006;
